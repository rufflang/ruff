{
  "scopeName": "source.ruff",
  "name": "Ruff",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#types"
    },
    {
      "include": "#function-definitions"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.ruff",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.ruff",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ruff",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ruff",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ruff",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.ruff",
              "begin": "\\\\$\\\\{",
              "end": "\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.ruff",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.ruff",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ruff",
          "match": "\\b(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ruff",
          "match": "\\b(?:if|else|match|case|while|for|in|loop|break|continue|return|try|except|throw|await|spawn)\\b"
        },
        {
          "name": "keyword.declaration.ruff",
          "match": "\\b(?:func|let|mut|const|struct|test|test_setup|test_teardown|test_group|async)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.ruff",
          "match": "\\b(?:true|false|null|None)\\b"
        },
        {
          "name": "constant.language.result.ruff",
          "match": "\\b(?:Ok|Err|Some)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.ruff",
          "match": "\\b(?:int|float|bool|string|array|dict|any|void|Result|Option)\\b"
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "name": "meta.function.definition.ruff",
          "match": "\\b(func)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.ruff"
            },
            "2": {
              "name": "entity.name.function.ruff"
            }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function.call.ruff",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.ruff"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.ruff",
          "match": ":=|=|\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.comparison.ruff",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.ruff",
          "match": "\\b(?:and|or|not)\\b"
        },
        {
          "name": "keyword.operator.arithmetic.ruff",
          "match": "\\+|-|\\*|/|%"
        }
      ]
    }
  },
  "uuid": "7d6edcb8-0ad2-4c3e-b5f1-3fd3b9d0a6f2"
}
